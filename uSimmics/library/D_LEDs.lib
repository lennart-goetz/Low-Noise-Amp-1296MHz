<QucsStudio Library 5.7 "LEDs">

<Component infrared>
  <Description>
classical infra-red light emitting diode
1.7V @ 20mA, U_rev_break = 5V
  </Description>
  <Model>
    .Def:LD_LEDs_infrared _netC _netA Package=""
      Diode:D_IR _netC _netA "1e-10" "3.45" "3 pF" "0.333" "0.75" "0.5" "0" "0" "2" "0.1" "4 us" "0" "0" "1" "1" "5" "10 uA" "26.85" "3" "1.11" "0" "0" "0" "0" "0" "0" "26.85" "1" "7.02e-4" "1108"
      R:Rleak _netA _netC "50M" "26.85"
    .Def:End
  </Model>
  <Symbol>
    .ID -26 13 D "0=Package=LED_3mm=PCB footprint [LED_3mm, LED_5mm]"
    Line -30 0 24 0 #000080 2 1
    Line 6 0 24 0 #000080 2 1
    Line -6 -9 0 18 #000080 2 1
    Line 6 -9 0 18 #000080 2 1
    Line -6 0 12 -9 #000080 2 1
    Line -6 0 12 9 #000080 2 1
    Arrow -5 -13 -10 -10 9 3 #000080 2 1 1
    Arrow 5 -13 -10 -10 9 3 #000080 2 1 1
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
  </Symbol>
</Component>

