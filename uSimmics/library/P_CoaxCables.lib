<QucsStudio Library 5.7 "Coaxial Cables">

<Component RG-58 C/U>
  <Description>
flexible coaxial cabel (50Ω)
frequency: max. 2 GHz
attenuation: 0.52 dB/m at 1GHz
outer diameter: 5 mm
shield: single braid copper
dielectric: PE (geometrical diameter 2.95 mm)
core: braid copper (geometrical diameter 0.9 mm)
  </Description>
  <Model>
    COAX RG58_ 1 0 0 -26 16 0 "2.3"0"3e-8"0"1"0"2.95 mm"0"0.83 mm"0"100m"1"3e-4"0"26.85"0
  </Model>
</Component>

<Component RG-58 C/U (4-port)>
  <Description>
differential variant of RG-58 C/U cable
4-port coaxial transmission line
useful for simulating stubs etc.
  </Description>
  <Model>
.Def:LP_CoaxCables_RG_58_C_U_4_port_ _net0 _net2 _net4 _net5 L=""
Tr:Tr1 _net0 _net1 gnd _net2 "1"
Tr:Tr2 _net3 _net4 _net5 gnd "1"
COAX:RG58 _net1 _net3 "2.3" "3e-8" "1" "2.95 mm" "0.83 mm" "L" "3e-4" "26.85"
.Def:End
  </Model>
  <Symbol>
    .ID -20 -52 RG58_ "1=L=10 mm=length of transmission line"
    .PortSym -30 0 1 0
    .PortSym -30 20 2 0
    .PortSym 30 0 3 180
    .PortSym 30 20 4 180
    Line -30 0 14 0 #000080 2 1
    Line 19 0 11 0 #000080 2 1
    Line -16 -9 32 0 #000080 2 1
    Line -16 9 32 0 #000080 2 1
    EArc -20 -9 8 18 0 5760 #000080 2 1
    EArc 11 -9 8 18 4320 2880 #000080 2 1
    Line -16 20 0 -10 #000080 2 1
    Line -30 20 14 0 #000080 2 1
    Line 16 19 0 -10 #000080 2 1
    Line 30 20 -14 0 #000080 2 1
  </Symbol>
</Component>

