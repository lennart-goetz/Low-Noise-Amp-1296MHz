<QucsStudio Library 5.6 "diverse">

<Component RF_resistor>
  <Description>
RF model of a resistor
with series inductance, parallel capacitance and
capacitance to ground at each terminal
as well as temperature dependency

typical values are:
case 0201:  100 pH, 42 fF
case 0402:  170 pH, 42 fF
case 0603:  260 pH, 45 fF
case 0805:  320 pH, 49 fF
case 1206:  550 pH, 42 fF

Temperature dependency:
R(Temp) = R · (1 + TC1·(Temp-Tnom) + TC2·(Temp-Tnom)²) · exp(Te·(Temp-Tnom))
  </Description>
  <Model>
    .Def:LS_diverse_RF_resistor _net1 _net0 R="" Ls="" Cp="" Cgnd="" Temp="" Tnom="" TC1="" TC2="" Te="" Package=""
      L:Ls _net0 _net1 "Ls" "R*(1+(TC1+TC2*(Temp-Tnom))*(Temp-Tnom)) * exp((Temp-Tnom)*Te)" ""
      C:Cp _net0 _net1 "Cp" "0" ""
      C:Cg1 _net0 gnd "Cgnd" "0" ""
      C:Cg2 _net1 gnd "Cgnd" "0" ""
    .Def:End
  </Model>
  <Symbol>
    .ID -20 14 R "1=R=50=resistance" "1=Ls=250 pH=series inductance" "1=Cp=45 fF=parallel capacitance" "0=Cgnd=2 fF=capacitance to ground at each terminal" "0=Temp=26.85=device temperature in °C" "0=Tnom=26.85=nominal device temperature" "0=TC1=2e-4=linear temperature coefficient" "0=TC2=0=quadratic temperature coefficient" "0=Te=0=exponent of temperature dependency" "0=Package=SMD0805=PCB footprint"
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
    Line -30 0 12 0 #000080 2 1
    Line 18 0 12 0 #000080 2 1
    Line -18 -9 36 0 #000080 2 1
    Line 18 -9 0 18 #000080 2 1
    Line 18 9 -36 0 #000080 2 1
    Line -18 9 0 -18 #000080 2 1
    EArc -6 -3 6 6 0 2880 #000080 2 1
    EArc 0 -3 6 6 2880 2880 #000080 2 1
  </Symbol>
</Component>

<Component RFcap>
  <Description>
RF model of a ceramic capacitor
with series inductance, series resistance
and parallel conductance
and linear temperature dependency

models the frequency-dependent impedance (small-signal)
does neither model the frequency-dependent loss
nor the bias-dependent capacitance

typical values for series inductance of an MLCC are:
case 0201:  200 pH
case 0402:  250 pH
case 0603:  330 pH
case 0805:  430 pH
typical values for series inductance of
leaded capacitors are:
1 nH per millimeter of wire
  </Description>
  <Model>
    .Def:LS_diverse_RFcap _net0 _net1 C="" L="" R="" G="" dT="" TC="" Package=""
      C:C1 _net2 _net0 "C*(TC*dT+1)" "G" ""
      L:L1 _net2 _net1 "L" "R" ""
    .Def:End
  </Model>
  <Symbol>
    .ID -20 14 C "1=C=100 pF=capacitance" "1=L=250 pH=series inductance" "1=R=0.1=series resistance" "0=G=1e-10=parallel conductance" "0=dT=0=temperature rise compared to nominal value" "0=TC=0=linear temperature coefficient" "0=Package=SMD0402=PCB footprint"
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
    Line -4 -11 0 22 #000080 4 1
    Line 4 -11 0 22 #000080 4 1
    Line -30 0 26 0 #000080 2 1
    Line 4 0 26 0 #000080 2 1
    EArc -25 -11 6 6 0 2880 #000080 2 1
    EArc -19 -11 6 6 2880 2880 #000080 2 1
  </Symbol>
</Component>

<Component capLoss>
  <Description>
RF model of a ceramic capacitor
with series inductance, series resistance,
parallel conductance and loss

models the frequency-dependent impedance
and the frequency-dependent loss
  </Description>
  <Model>
    .Def:LS_diverse_capLoss _net0 _net1 C="" L="" R="" G="" RL="" CL="" Package=""
      R:R3 _net2 _net3 "6.5*RL" "26.85"
      R:R4 _net2 _net4 "6.5*6.5*RL" "26.85"
      R:R5 _net2 _net5 "6.5*6.5*6.5*RL" "26.85"
      R:R6 _net2 _net6 "6.5*6.5*6.5*6.5*RL" "26.85"
      R:R7 _net2 _net7 "6.5*6.5*6.5*6.5*6.5*RL" "26.85"
      R:R2 _net2 _net8 "RL" "26.85"
      L:L1 _net1 _net2 "L" "R" ""
      C:C1 _net2 _net0 "C*(1-6*CL)" "G" ""
      C:C2 _net8 _net0 "CL*C" "0" ""
      C:C3 _net3 _net0 "CL*C" "0" ""
      C:C4 _net4 _net0 "CL*C" "0" ""
      C:C5 _net5 _net0 "CL*C" "0" ""
      C:C6 _net6 _net0 "CL*C" "0" ""
      C:C7 _net7 _net0 "CL*C" "0" ""
    .Def:End
  </Model>
  <Symbol>
    .ID -20 14 C "1=C=100 pF=capacitance" "1=L=250 pH=series inductance" "1=R=1=series resistance" "1=G=1e-10=parallel conductance" "1=RL=5000=frequency-dependent loss factor" "0=CL=0.011=frequency-dependent loss factor" "0=Package=SMD0402=PCB footprint"
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
    Line -4 -11 0 22 #000080 4 1
    Line 4 -11 0 22 #000080 4 1
    Line -30 0 26 0 #000080 2 1
    Line 4 0 26 0 #000080 2 1
    EArc -25 -11 6 6 0 2880 #000080 2 1
    EArc -19 -11 6 6 2880 2880 #000080 2 1
  </Symbol>
</Component>

<Component capNonLinear>
  <Description>
voltage-dependent capacitor
models a typical multi-layer chip capacitor (MLCC)
  </Description>
  <Model>
    .Def:LS_diverse_capNonLinear _net0 _net1 C="" Vr="" csat="" Vc="" Rp="" Rs="" Ls=""
      L:Ls _net2 _net1 "Ls" "Rs" "" "inductor_1mH"
      EDD:Cnl _net0 _net2 "1" "_v1/Rp" "C*((1-csat)*Vr*tanh((_v1+Vc)/Vr)+csat*_v1)"
    .Def:End
  </Model>
  <Symbol>
    .ID -20 14 C "1=C=100 nF=nominal (maximum) capacitance" "1=Vr=16 V=rated (maximum) voltage" "0=csat=0.1=ratio of saturation and nominal capacitance" "0=Vc=0=coercive voltage (voltage with maximum capacitance)" "0=Rp=1 GΩ=parasitic parallel resistance" "0=Rs=0=series resistance" "0=Ls=0=series inductance"
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
    Line -4 -11 0 22 #000080 4 1
    Line 4 -11 0 22 #000080 4 1
    Line -30 0 26 0 #000080 2 1
    Line 4 0 26 0 #000080 2 1
    Line -20 10 40 -20 #000080 1 1
  </Symbol>
</Component>

<Component Qcoil>
  <Description>
model of a non-ideal coil
with series resistance and parallel capacitance

models the frequency-dependent impedance (small-signal)
does not model the frequency-dependent loss
  </Description>
  <Model>
    .Def:LS_diverse_Qcoil _net0 _net1 L="" fres="" R="" Package=""
      L:L1 _net0 _net1 "L" "R" ""
      C:C1 _net0 _net1 "0.25/(pi*fres)^2/L" "0" ""
    .Def:End
  </Model>
  <Symbol>
    .ID -20 14 L "1=L=1 µH=inductance" "1=fres=100 MHz=resonance frequency" "1=R=0.1=series resistance" "0=Package=inductor_1mH=PCB footprint"
    Line -30 0 12 0 #000080 2 1
    Line 18 0 12 0 #000080 2 1
    EArc -18 -6 12 12 0 2880 #000080 2 1
    EArc -6 -6 12 12 0 2880 #000080 2 1
    EArc 6 -6 12 12 0 2880 #000080 2 1
    Line -17 -11 8 0 #000080 2 1
    Line -4 -11 8 0 #000080 2 1
    Line 9 -11 8 0 #000080 2 1
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
  </Symbol>
</Component>

<Component RFcoil>
  <Description>
old Coilcraft model for RF coils
consists of
1) frequency-dependend series resistance
2) parallel capacitance with series resistance
see www.coilcraft.com/models.cfm for details

models the frequency-dependent impedance (small-signal)
and the frequency-dependent loss (skin effect)
  </Description>
  <Model>
    .Def:LS_diverse_RFcoil _net3 _net4 L="" R2="" C="" R1="" k="" Package=""
      L:L _net0 _net1 "L" "0" ""
      C:Cpar _net2 _net0 "C" "0" ""
      R:Rdc _net3 _net0 "R2" "26.85"
      R:Rcap _net2 _net4 "R1" "26.85"
      RFEDD:Rrf _net1 _net4 "A" "2" "short" "1" "k*sqrt(freq)" "0" "1"
    .Def:End
  </Model>
  <Symbol>
    .ID -20 14 L "1=L=100 nH=inductance" "1=R2=0.01=DC series resistance" "1=C=60 fF=parasitic parallel capacitance" "1=R1=25=series resistance of parasitic capacitance" "1=k=2.34e-4=factor for series resistance (skin effect)" "0=Package=inductor_1mH=PCB footprint"
    Line -30 0 12 0 #000080 2 1
    Line 18 0 12 0 #000080 2 1
    EArc -18 -6 12 12 0 2880 #000080 2 1
    EArc -6 -6 12 12 0 2880 #000080 2 1
    EArc 6 -6 12 12 0 2880 #000080 2 1
    Line -17 -11 8 0 #000080 2 1
    Line -4 -11 8 0 #000080 2 1
    Line 9 -11 8 0 #000080 2 1
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
  </Symbol>
</Component>

<Component AirCoil>
  <Description>
Coilcraft model for RF coils
consists of
1) transmission line to model the inductance
2) parallel capacitance with series resistance
see www.coilcraft.com/models.cfm for details

models the frequency-dependent impedance (small-signal)
does not correctly model the frequency-dependent loss
  </Description>
  <Model>
    .Def:LS_diverse_AirCoil _net1 _net0 R1="" R2="" C="" Z0="" EL="" F0="" Package=""
      TLIN:Line _net1 _net2 "Z0" "c0/F0*EL/360" "0 dB" "26.85" "" ""
      C:Cpar _net3 _net1 "C" "0" ""
      R:Rser _net2 _net0 "R2" "26.85"
      R:Rcap _net3 _net0 "R1" "26.85"
    .Def:End
  </Model>
  <Symbol>
    .ID -20 14 L "1=R1=2.4=series resistance of parasitic capacitance" "1=R2=0.7=series resistance of inductance" "1=C=314 fF=parasitic parallel capacitance" "1=Z0=385=line impedance of coil wire" "1=EL=80=electrical line length in degree" "1=F0=886 MHz=frequency for line length" "0=Package=inductor_1mH=PCB footprint"
    Line -30 0 12 0 #000080 2 1
    Line 18 0 12 0 #000080 2 1
    EArc -18 -6 12 12 0 2880 #000080 2 1
    EArc -6 -6 12 12 0 2880 #000080 2 1
    EArc 6 -6 12 12 0 2880 #000080 2 1
    Line -17 -11 8 0 #000080 2 1
    Line -4 -11 8 0 #000080 2 1
    Line 9 -11 8 0 #000080 2 1
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
  </Symbol>
</Component>

<Component tappedcoil>
  <Description>
inductance with tap
  </Description>
  <Model>
    .Def:LS_diverse_tappedcoil _net0 _net1 _net2 L="" n1="" n2="" k="" R=""
      MUT:TM _net0 _net2 _net1 _net2 "L*(n1/(n1+n2))^2" "L*(n2/(n1+n2))^2" "k" "R*n1/(n1+n2)" "R*n2/(n1+n2)"
    .Def:End
  </Model>
  <Symbol>
    Line 0 -24 0 -6 #000080 2 1
    Line -10 0 12 0 #000080 2 1
    Line 0 30 0 -6 #000080 2 1
    EArc -6 0 12 12 4320 2880 #000080 2 1
    EArc -6 -12 12 12 4320 2880 #000080 2 1
    EArc -6 -24 12 12 4320 2880 #000080 2 1
    EArc -6 12 12 12 4320 2880 #000080 2 1
    Text -11 -29 10 #000000 0 "1"
    Text -12 14 10 #000000 0 "2"
    .PortSym 0 30 2 90
    .PortSym 0 -30 1 270
    .PortSym -10 0 3 0
    .ID 20 -26 L "1=L=1 µH=overall inductance" "1=n1=2=number of turns (high end)" "1=n2=2=number of turns (low end)" "0=k=1=coupling factor" "0=R=0=overall resistance of coil wire"
  </Symbol>
</Component>

<Component potentiometer>
  <Description>
variable resistance
  </Description>
  <Model>
    .Def:LS_diverse_potentiometer _net0 _net1 _net2 R="" k="" Package=""
      R:R1 _net0 _net1 "R*k" "26.85"
      R:R2 _net1 _net2 "R*(1-k)" "26.85"
    .Def:End
  </Model>
  <Symbol>
    Line -30 0 12 0 #000080 2 1
    Line 18 0 12 0 #000080 2 1
    Line -18 -9 36 0 #000080 2 1
    Line 18 -9 0 18 #000080 2 1
    Line 18 9 -36 0 #000080 2 1
    Line -18 9 0 -18 #000080 2 1
    Arrow 0 30 0 -20 8 4 #000080 2 1 1
    .PortSym -30 0 1 0
    .PortSym 0 30 2 90
    .PortSym 30 0 3 180
    .ID -20 -76 R "1=R=1k=total resistance in ohms" "1=k=0.5=positio of middle pin (0...1)" "0=Package=trimmer=PCB footprint [trimmer, trimmer_long, trimmer_spread]"
  </Symbol>
</Component>

<Component loudspeaker>
  <Description>
small-signal model of electrodynamic loudspeaker
(dispersive frequency-domain model)
  </Description>
  <Model>
    .Def:LS_diverse_loudspeaker _net0 _net1 Re="" n="" K="" fs="" Qms="" Res="" Package=""
      RFEDD:X1 _net0 _net1 "A" "2" "zerofrequency" "1" "Re + K * S^n + Res*S / (S + Qms*(S*S/2/pi/fs + 2*pi*fs))" "0" "1"
    .Def:End
  </Model>
  <Symbol>
    Line -10 10 20 0 #000080 2 1
    Line -10 -10 20 0 #000080 2 1
    Line 10 -20 0 40 #000080 4 1
    Line 10 -10 10 -10 #000080 2 1
    Line 10 10 10 10 #000080 2 1
    Line -10 -10 0 20 #000080 2 1
    Line 20 -20 0 40 #000080 2 1
    Line 0 10 0 20 #000080 2 1
    Line 0 -30 0 20 #000080 2 1
    .PortSym 0 -30 1 270
    .PortSym 0 30 2 90
    .ID 30 -26 L "1=Re=5=DC resistance of voice-coil" "1=n=0.7=frequency exponent of lossy inductance (0...1 with 1 for a lossless inductor)" "1=K=0.025=factor of lossy inductance" "0=fs=35=resonance frequency of driver in Hertz" "0=Qms=2.8=mechanical quality factor" "0=Res=32=resonance resistance in ohms" "0=Package=con_2=PCB footprint [con_2, smd_jumper, buzzer, buzzer_kpeg251]"
  </Symbol>
</Component>

<Component crystal>
  <Description>
first order model (small-signal)
  </Description>
  <Model>
    .Def:LS_diverse_crystal _net0 _net2 freq="" Rs="" Q="" Cp="" Package=""
      L:L1 _net0 _net1 "Q*Rs/(2*pi*freq)" "0" ""
      C:Cp _net0 _net2 "Cp" "0" ""
      R:Rs _net3 _net2 "Rs" "26.85"
      C:C1 _net1 _net3 "1/(2*pi*freq*Q*Rs)" "0" ""
    .Def:End
  </Model>
  <Symbol>
    .PortSym -30 0 1 0
    Line -30 0 20 0 #000080 2 1
    Line 10 0 20 0 #000080 2 1
    .PortSym 30 0 2 180
    Line 10 -8 0 16 #000080 3 1
    Line -10 -8 0 16 #000080 3 1
    Line 5 10 0 -20 #000080 2 1
    Line -5 10 0 -20 #000080 2 1
    Line -5 -10 10 0 #000080 2 1
    Line -5 10 10 0 #000080 2 1
    .ID -30 20 X "1=freq=1 MHz=(serial) resonance frequency" "0=Rs=540=serial resistance" "0=Q=1000=quality factor" "0=Cp=13 pF=parallel capacitance" "0=Package=crystal_HC18=PCB footprint [crystal_HC18, crystal_32768]"
  </Symbol>
</Component>

