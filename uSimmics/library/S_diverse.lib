<Component NTC>
  <Description>
NTC thermistor (negative temperature coefficient)
resistor with exponential temperature dependency
R = Rn * exp(B/(Temp+273.15) - B/(Tn+273.15))
  </Description>
  <Model>
    .Def:LS_diverse_NTC _net0 _net1 Rn="" Tn="" B="" Temp="" Package=""
      R:R1 _net0 _net1 "Rn * exp(B/(Temp-T0K) - B/(Tn-T0K))" "Temp"
    .Def:End
  </Model>
  <Symbol>
    Line -30 0 12 0 #000080 2 1
    Line 18 0 12 0 #000080 2 1
    Line -18 -9 36 0 #000080 2 1
    Line 18 -9 0 18 #000080 2 1
    Line 18 9 -36 0 #000080 2 1
    Line -18 9 0 -18 #000080 2 1
    Line -20 20 40 -40 #000080 2 1
    Line -30 20 10 0 #000080 2 1
    .PortSym -30 0 1 0
    .PortSym 30 0 2 180
    .ID -20 24 NTC "1=Rn=10k=nominal resistance" "1=Tn=25=nominal temperature in °C" "1=B=3000=material constant in K (B value)" "0=Temp=25=device temperature in °C" "0=Package=con_2=PCB footprint"
  </Symbol>
</Component>

